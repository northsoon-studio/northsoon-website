---
import "../styles/global.css";
import { AstroHead } from "@northsoon/astro-seo";
---
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <AstroHead
  title="Northsoon Studio"
  description="Web design agency specializing in fast, SEO-optimized websites for trades, construction, and industrial businesses."
  canonical="https://northsoon.com"
  openGraph={{
    url: "https://northsoon.com/",
    type: "website",
    title: "Northsoon - Web Design & Development",
    description: "Web design agency specializing in fast, SEO-optimized websites for trades, construction, and industrial businesses.",
    site_name: "Northsoon",
    images: [
      {
        url: "https://northsoon.com/social_banner.png",
        width: 1200,
        height: 630,
      },
    ],
  }}
  twitter={{
    handle: "@northsoon_dev",
    site: "@northsoon_dev",
    cardType: "summary_large_image",
  }}
  additionalLinkTags={[
    { rel: "icon", href: "/favicon-32x32.png" },
    { rel: "icon", type: "image/png", sizes: "96x96", href: "/favicon-96x96.png" },
    { rel: "apple-touch-icon", sizes: "180x180", href: "/apple-icon-180x180.png" },
  ]}
  additionalMetaTags={[
    { name: "theme-color", content: "#BCC2F7" },
    { name: "author", content: "Manuel - Northsoon" },
  ]}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Northsoon Studio",
    "url": "https://northsoon.com",
    "description": "Web design agency specializing in fast, SEO-optimized websites for trades, construction, and industrial businesses.",
    "areaServed": ["Canada", "United States"]
  }}
/>

    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script async src="https://unpkg.com/mailgo@0.12.2/dist/mailgo.min.js"></script>