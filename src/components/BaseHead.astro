---
import "../styles/global.css";
---
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta name="language" content="en-US">

    <title>Northsoon - Web Design & Development Agency</title>

    <link rel="icon" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-icon-180x180.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/android-icon-192x192.png" />

    <meta name="theme-color" content="#BCC2F7" />
    <meta name="author" content="Manuel – Northsoon" />
    <meta name="keywords" content="Web design, development, Tailwind, Astro, clean design, responsive websites, Northsoon" />
    <meta name="description" content="Northsoon creates clean, functional, and fast websites using Astro and Tailwind. Get started today and see how we can help you build your next web project." />

    <meta property="og:title" content="Northsoon – Web Design & Development" />
    <meta property="og:description" content="Clean and thoughtful digital solutions. Tailored design & development using Astro & Tailwind." />
    <meta property="og:image" content="/social_banner.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content="https://northsoon.com/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Northsoon" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@northsoon_dev" />
    <meta name="twitter:title" content="Northsoon – Web Design & Development" />
    <meta name="twitter:description" content="Clean and thoughtful digital solutions. Tailored design & development using Astro & Tailwind." />
    <meta name="twitter:image" content="/social_banner.png" />

    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
